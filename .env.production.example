# ─── Đổi tất cả giá trị bên dưới trước khi deploy ───

# Cổng host map ra ngoài (Caddy/Nginx sẽ proxy vào đây)
HOST_PORT=3000

# Domain công khai (KHÔNG có dấu / cuối)
NEXTAUTH_URL=https://your-domain.com

# Bí mật ký JWT — sinh bằng: openssl rand -base64 48
NEXTAUTH_SECRET=REPLACE_ME_RANDOM_BASE64_48_BYTES

# Upstream AI provider (để trống nếu thêm key qua admin UI)
TCDMX_API_KEY=
TCDMX_BASE_URL=https://tcdmx.com

# Bí mật mã hoá API key lưu trong DB — sinh bằng: openssl rand -base64 32
KEY_ENCRYPTION_SECRET=REPLACE_ME_RANDOM_BASE64_32_BYTES

# SMTP để gửi mã OTP đăng ký + reset mật khẩu
# (Gmail App Password / SendGrid / Resend SMTP đều dùng được)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="AI Gateway <noreply@your-domain.com>"

# ─── Tài khoản admin (chỉ dùng cho seed ban đầu) ───
ADMIN_EMAIL=binhminh22227@gmail.com
ADMIN_PASSWORD=ReplaceWithStrongPasswordMin12Chars
